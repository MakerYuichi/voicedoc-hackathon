# Google Cloud & Gemini
GOOGLE_API_KEY=GOOGLE_API_KEY
GOOGLE_CLOUD_PROJECT=GOOGLE_PROJECT_ID
GOOGLE_APPLICATION_CREDENTIALS=GOOGLE_APPLICATION_CREDENTIALS

# MongoDB Atlas
MONGODB_URI=mongodb_ui
MONGODB_DATABASE=voicedoc_intelligence

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Frontend
FRONTEND_URL=http://localhost:3000

# MongoDB MCP Server
MCP_SERVER_PATH=path/to/mongodb-mcp-server
MCP_SERVER_PORT=5000

# Security
SECRET_KEY=your_secret_key_here_min_32_chars
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Agent Settings
MAX_PARALLEL_WORKERS=4
DOCUMENT_CHUNK_SIZE=512
DOCUMENT_CHUNK_OVERLAP=50
EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_MODEL=gemini-2.0-flash

# Groq (dev/test fallback — optional)
# Set GROQ_API_KEY to enable. Leave blank to use Gemini.
# NOTE: For production/hackathon submission, Gemini is always used.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
TEMPERATURE=0.7
MAX_TOKENS=2048

# Vector Search
VECTOR_INDEX_NAME=vector_index_1
VECTOR_DIMENSIONS=3072
SIMILARITY_THRESHOLD=0.7
TOP_K_RESULTS=5
